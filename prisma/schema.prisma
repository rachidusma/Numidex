generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = "postgresql://postgres.opjdnghtpvltwalfpgjs:Ra0794420337@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
  directUrl = "postgresql://postgres.opjdnghtpvltwalfpgjs:Ra0794420337@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"
}

model Admin {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?
}

model Category {
  id             String    @id @default(cuid())
  name           String
  name_fr        String?
  description    String?
  description_fr String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  description_pt String?
  name_pt        String?
  description_ar String?
  name_ar        String?
  products       Product[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  name_fr        String?
  description    String?
  description_fr String?
  image          String?
  categoryId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isAvailable    Boolean  @default(true)
  description_pt String?
  name_pt        String?
  description_ar String?
  name_ar        String?
  category       Category @relation(fields: [categoryId], references: [id])
}

model SiteVisit {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  userAgent String?
  ipAddress String?
  path      String?
  country   String?

  @@map("visits_numidex")
}
